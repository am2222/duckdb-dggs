# name: test/sql/duck_dggs.test
# description: test duck_dggs extension
# group: [sql]

require duck_dggs

# ============================================================
# Utility
# ============================================================

query I
SELECT duck_dggs_version() != '';
----
true

# ============================================================
# FROM GEO — (lon=0.0, lat=0.0, res=5)
#
# NOTE: (0.0, 0.0) sits on an icosahedron face boundary.
# DGGRID assigns it to one of the adjacent cells depending on
# floating-point evaluation order, which differs between x86
# (80-bit x87 long double) and ARM/macOS (64-bit double).
# Integer results (seqnum, q2di quad/i/j) are stable; all
# continuous-coordinate results use fuzzy comparisons.
# ============================================================

query I
SELECT geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 5);
----
2380

query I
SELECT geo_to_q2di('POINT(0.0 0.0)'::GEOMETRY, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# geo_to_q2dd: quad is an integer (stable); x and y are continuous
# coordinates whose last bits differ between x86 and ARM.
query I
SELECT (geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).quad = 3
   AND abs((geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.16325419438415284) < 1e-9
   AND abs((geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).y - 0.282764559254556) < 1e-9;
----
true

# geo_to_projtri: (0,0) lands on the boundary between icosahedron triangles 2
# and 7.  Accept either adjacent triangle; check coordinates to 1e-9.
query I
SELECT
  (((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).tnum = 7 AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.6734916112035678) < 1e-9)
   OR
   ((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).tnum = 2 AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.32650838876079025) < 1e-9))
  AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).y) < 1e-9;
----
true

query I
SELECT geo_to_geo('POINT(0.0 0.0)'::GEOMETRY, 5);
----
POINT (0 0)

# geo_to_plane: (0,0) sits on a plane-triangle boundary; x shifts by exactly
# 1.0 between platforms.  y is √3 on both platforms — check within 1e-9.
query I
SELECT
  (abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 3.326508388796432)   < 1e-9
   OR abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 2.3265083887607902) < 1e-9)
  AND abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).y - 1.7320508075851162) < 1e-9;
----
true

# ============================================================
# FROM SEQNUM — (seqnum=2380, res=5)
# ============================================================

query I
SELECT seqnum_to_q2di(2380, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# seqnum_to_q2dd: x = 5/32 (exact); y is a continuous value that may
# differ in the last bits across platforms.
query I
SELECT (seqnum_to_q2dd(2380, 5)).quad = 3
   AND (seqnum_to_q2dd(2380, 5)).x = 0.15625
   AND abs((seqnum_to_q2dd(2380, 5)).y - 0.27063293868263705) < 1e-9;
----
true

# seqnum_to_projtri: x is very close to 11/16 = 0.6875; y is essentially
# zero (floating-point noise) — check abs(y) < 1e-9.
query I
SELECT (seqnum_to_projtri(2380, 5)).tnum = 7
   AND abs((seqnum_to_projtri(2380, 5)).x - 0.6875) < 1e-9
   AND abs((seqnum_to_projtri(2380, 5)).y) < 1e-9;
----
true

# seqnum_to_plane: x = 37/16 (exact); y is approximately √3 and may
# differ in the last bits across platforms.
query I
SELECT (seqnum_to_plane(2380, 5)).x = 2.3125
   AND abs((seqnum_to_plane(2380, 5)).y - 1.7320508075688774) < 1e-9;
----
true

# seqnum_to_seqnum is a round-trip identity
query I
SELECT seqnum_to_seqnum(2380, 5);
----
2380

# ============================================================
# FROM Q2DI — (quad=3, i=10, j=10, res=5)
# ============================================================

query I
SELECT q2di_to_seqnum(3, 10, 10, 5);
----
2380

query I
SELECT q2di_to_q2di(3, 10, 10, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# q2di_to_q2dd: same result as seqnum_to_q2dd — same fuzzy check.
query I
SELECT (q2di_to_q2dd(3, 10, 10, 5)).quad = 3
   AND (q2di_to_q2dd(3, 10, 10, 5)).x = 0.15625
   AND abs((q2di_to_q2dd(3, 10, 10, 5)).y - 0.27063293868263705) < 1e-9;
----
true

# ============================================================
# Round-trips
# ============================================================

# geo → seqnum → geo → seqnum must be stable (cell centre)
query I
SELECT geo_to_seqnum(seqnum_to_geo(2380, 5), 5);
----
2380

# q2di → seqnum → q2di must be stable
query I
SELECT seqnum_to_q2di(q2di_to_seqnum(3, 10, 10, 5), 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# seqnum → q2di → seqnum must be stable
query I
SELECT q2di_to_seqnum((seqnum_to_q2di(2380, 5)).quad, (seqnum_to_q2di(2380, 5)).i, (seqnum_to_q2di(2380, 5)).j, 5);
----
2380

# ============================================================
# Vectorised — works on a table of values
# ============================================================

query I
SELECT count(*) = 3 FROM (
    SELECT geo_to_seqnum(geom, 5)
    FROM (VALUES ('POINT(0.0 0.0)'::GEOMETRY), ('POINT(10.0 20.0)'::GEOMETRY), ('POINT(-45.0 60.0)'::GEOMETRY)) t(geom)
);
----
true

# Different resolutions produce different cell counts
query I
SELECT geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 1) != geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 5);
----
true

# ============================================================
# FROM Q2DD — (quad=3, x=0.15625, y=0.27063293868263705, res=5)
# ============================================================

query I
SELECT q2dd_to_seqnum(3, 0.15625, 0.27063293868263705, 5);
----
2380

query I
SELECT q2dd_to_q2di(3, 0.15625, 0.27063293868263705, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

query I
SELECT (q2dd_to_projtri(3, 0.15625, 0.27063293868263705, 5)).tnum = 7;
----
true

# q2dd_to_geo produces the same cell centre as the canonical seqnum
query I
SELECT geo_to_seqnum(q2dd_to_geo(3, 0.15625, 0.27063293868263705, 5), 5);
----
2380

# ============================================================
# FROM PROJTRI — (tnum=7, x=0.6875, y=0.0, res=5)
# ============================================================

query I
SELECT projtri_to_seqnum(7, 0.6875, 0.0, 5);
----
2380

query I
SELECT projtri_to_q2di(7, 0.6875, 0.0, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

query I
SELECT abs((projtri_to_plane(7, 0.6875, 0.0, 5)).x - 2.3125) < 1e-9
   AND abs((projtri_to_plane(7, 0.6875, 0.0, 5)).y - 1.7320508075688772) < 1e-9;
----
true

# projtri_to_geo produces the same cell centre as the canonical seqnum
query I
SELECT geo_to_seqnum(projtri_to_geo(7, 0.6875, 0.0, 5), 5);
----
2380

query I
SELECT (projtri_to_q2dd(7, 0.6875, 0.0, 5)).quad = 3;
----
true

# ============================================================
# Cross-frame round-trips
# ============================================================

# GEO → Q2DI → SEQNUM matches GEO → SEQNUM
query I
SELECT q2di_to_seqnum(
    (geo_to_q2di('POINT(10.0 20.0)'::GEOMETRY, 5)).quad,
    (geo_to_q2di('POINT(10.0 20.0)'::GEOMETRY, 5)).i,
    (geo_to_q2di('POINT(10.0 20.0)'::GEOMETRY, 5)).j, 5)
  = geo_to_seqnum('POINT(10.0 20.0)'::GEOMETRY, 5);
----
true

# GEO → Q2DD → SEQNUM matches GEO → SEQNUM
query I
SELECT q2dd_to_seqnum(
    (geo_to_q2dd('POINT(10.0 20.0)'::GEOMETRY, 5)).quad,
    (geo_to_q2dd('POINT(10.0 20.0)'::GEOMETRY, 5)).x,
    (geo_to_q2dd('POINT(10.0 20.0)'::GEOMETRY, 5)).y, 5)
  = geo_to_seqnum('POINT(10.0 20.0)'::GEOMETRY, 5);
----
true

# GEO → PROJTRI → Q2DI → SEQNUM matches GEO → SEQNUM
query I
SELECT q2di_to_seqnum(
    (projtri_to_q2di(
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).tnum,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).x,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).y, 5)).quad,
    (projtri_to_q2di(
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).tnum,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).x,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).y, 5)).i,
    (projtri_to_q2di(
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).tnum,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).x,
        (geo_to_projtri('POINT(10.0 20.0)'::GEOMETRY, 5)).y, 5)).j,
    5) = geo_to_seqnum('POINT(10.0 20.0)'::GEOMETRY, 5);
----
true

# ============================================================
# dggs_params — 8-arg overload (aperture sequence support)
# ============================================================

# 6-arg overload defaults is_aperture_sequence=false
query I
SELECT (dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)).is_aperture_sequence;
----
false

# 6-arg overload defaults aperture_sequence=''
query I
SELECT (dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)).aperture_sequence;
----
(empty)

# 8-arg overload sets is_aperture_sequence
query I
SELECT (dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3437')).is_aperture_sequence;
----
true

# 8-arg overload sets aperture_sequence
query I
SELECT (dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3437')).aperture_sequence;
----
3437

# ============================================================
# Grid Statistics — dggs_n_cells, dggs_cell_area_km,
#                   dggs_cell_dist_km, dggs_cls_km,
#                   dggs_res_info
# ============================================================

# Known cell count for ISEA4H at res 4
query I
SELECT dggs_n_cells(4);
----
2562

# Known cell count at res 5
query I
SELECT dggs_n_cells(5);
----
10242

# Higher resolution has more cells
query I
SELECT dggs_n_cells(5) > dggs_n_cells(4);
----
true

# Higher resolution has smaller area per cell
query I
SELECT dggs_cell_area_km(5) < dggs_cell_area_km(4);
----
true

# All stats are positive
query I
SELECT dggs_cell_area_km(4) > 0
   AND dggs_cell_dist_km(4) > 0
   AND dggs_cls_km(4) > 0;
----
true

# dggs_res_info struct fields match individual functions
query I
SELECT (dggs_res_info(4)).cells = dggs_n_cells(4);
----
true

query I
SELECT (dggs_res_info(4)).res = 4;
----
true

# Params overload: stats with explicit default params match base overload
query I
SELECT dggs_n_cells(4, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)) = dggs_n_cells(4);
----
true

# Different aperture gives different cell count
query I
SELECT dggs_n_cells(4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))
    != dggs_n_cells(4);
----
true

# ── aperture sequence grid stats ────────────────────────────

# Aperture sequence produces a different cell count than fixed aperture
query I
SELECT dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'))
    != dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

query I
SELECT dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
362

# ============================================================
# Neighbors — seqnum_neighbors
# ============================================================

# Interior hexagon cell has 6 neighbors
query I
SELECT len(seqnum_neighbors(2380::UBIGINT, 5));
----
6

# A cell is not its own neighbor
query I
SELECT list_contains(seqnum_neighbors(2380::UBIGINT, 5), 2380::UBIGINT);
----
false

# Neighbor relationship is symmetric
query I
SELECT list_contains(seqnum_neighbors(2412::UBIGINT, 5), 2380::UBIGINT);
----
true

# Params overload matches base form
query I
SELECT seqnum_neighbors(2380::UBIGINT, 5)
     = seqnum_neighbors(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# Vectorised over a table
query I
SELECT count(*) = 3 FROM (
  SELECT seqnum_neighbors(seqnum, 5)
  FROM (VALUES (2380::UBIGINT), (2381::UBIGINT), (100::UBIGINT)) t(seqnum)
);
----
true

# ============================================================
# Parent — seqnum_parent
# ============================================================

query I
SELECT seqnum_parent(2380::UBIGINT, 5);
----
599

# Parent is at the coarser resolution: its children include the original cell
query I
SELECT list_contains(
    seqnum_children(seqnum_parent(2380::UBIGINT, 5), 4),
    2380::UBIGINT
);
----
true

# Params overload matches base form
query I
SELECT seqnum_parent(2380::UBIGINT, 5)
     = seqnum_parent(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Children — seqnum_children
# ============================================================

# Aperture 4 hexagon cell has 7 children (1 interior + 6 boundary)
query I
SELECT len(seqnum_children(599::UBIGINT, 4));
----
7

# The interior child's parent is the original cell
query I
SELECT seqnum_parent((seqnum_children(599::UBIGINT, 4))[1], 5);
----
599

# Params overload matches base form
query I
SELECT seqnum_children(599::UBIGINT, 4)
     = seqnum_children(599::UBIGINT, 4, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Hierarchical addresses — ZOrder, Z3, Z7 round-trips
# ============================================================

# ── ZOrder (default aperture 4) ─────────────────────────────

query I
SELECT zorder_to_seqnum(seqnum_to_zorder(2380::UBIGINT, 5), 5);
----
2380

# ── Z3 (requires aperture 3) ────────────────────────────────

query I
SELECT z3_to_seqnum(
    seqnum_to_z3(100::UBIGINT, 4,
        dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)),
    4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
100

# ── Z7 (requires aperture 7) ────────────────────────────────

query I
SELECT z7_to_seqnum(
    seqnum_to_z7(100::UBIGINT, 4,
        dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)),
    4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
100

# ZOrder params overload matches base form (default is aperture 4)
query I
SELECT seqnum_to_zorder(2380::UBIGINT, 5)
     = seqnum_to_zorder(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# All Parents — seqnum_all_parents
# ============================================================

# Interior cell: all_parents returns exactly the primary parent
query I
SELECT len(seqnum_all_parents(2380::UBIGINT, 5));
----
1

# Primary parent is the first element
query I
SELECT (seqnum_all_parents(2380::UBIGINT, 5))[1] = seqnum_parent(2380::UBIGINT, 5);
----
true

# Boundary cell (2412 sits on the boundary between parents) has multiple parents
query I
SELECT len(seqnum_all_parents(2412::UBIGINT, 5)) > 1;
----
true

# The primary (containing) parent is always in the list
query I
SELECT list_contains(
    seqnum_all_parents(2412::UBIGINT, 5),
    seqnum_parent(2412::UBIGINT, 5)
);
----
true

# Params overload matches base form
query I
SELECT seqnum_all_parents(2380::UBIGINT, 5)
     = seqnum_all_parents(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Vertex2DD — seqnum_to_vertex2dd, vertex2dd_to_seqnum
# ============================================================

# Round-trip: vertex2dd → seqnum recovers the original
query I
SELECT vertex2dd_to_seqnum(
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).keep,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).vert_num,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).tri_num,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).x,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).y,
    5
);
----
2380

# Struct fields have expected types: keep is boolean, vert_num/tri_num are ints
query I
SELECT (seqnum_to_vertex2dd(2380::UBIGINT, 5)).keep;
----
true

# Params overload matches base form
query I
SELECT seqnum_to_vertex2dd(2380::UBIGINT, 5)
     = seqnum_to_vertex2dd(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Aperture sequence — transforms
# ============================================================

# seqnum round-trip through aperture-sequence grid
query I
SELECT seqnum_to_seqnum(100::UBIGINT, 3,
    dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
100

# ============================================================
# Grid Statistics — exact values at res 1
# ============================================================

query I
SELECT abs(dggs_cell_area_km(1) - 12751640.543102216) < 1.0;
----
true

query I
SELECT abs(dggs_cell_dist_km(1) - 3526.826215705416) < 0.01;
----
true

query I
SELECT abs(dggs_cls_km(1) - 4046.359550783672) < 0.01;
----
true

# ============================================================
# Error cases
# ============================================================

# seqnum_parent at resolution 0 throws error
statement error
SELECT seqnum_parent(1::UBIGINT, 0);
----
already at resolution 0

# seqnum_to_zorder with aperture 7 throws error
statement error
SELECT seqnum_to_zorder(1::UBIGINT, 4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
ZORDER not available

# seqnum_to_z3 with default aperture 4 throws error
statement error
SELECT seqnum_to_z3(1::UBIGINT, 4);
----
Z3 not available

# seqnum_to_z7 with default aperture 4 throws error
statement error
SELECT seqnum_to_z7(1::UBIGINT, 4);
----
Z7 not available

# ============================================================
# Parent / Child — additional tests
# ============================================================

# Interior child's parent matches the original cell
query I
SELECT seqnum_parent((seqnum_children(599::UBIGINT, 4))[1], 5) = 599;
----
true

# Children count: aperture 3 hex cell also has 7 children
query I
SELECT len(seqnum_children(10::UBIGINT, 3,
    dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)));
----
7

# Children count: aperture 7 hex cell has 13 children
query I
SELECT len(seqnum_children(10::UBIGINT, 3,
    dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)));
----
13

# ============================================================
# Hierarchical addresses — additional tests
# ============================================================

# VERTEX2DD round-trip with aperture 3
query I
SELECT vertex2dd_to_seqnum(
    (seqnum_to_vertex2dd(100::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).keep,
    (seqnum_to_vertex2dd(100::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).vert_num,
    (seqnum_to_vertex2dd(100::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).tri_num,
    (seqnum_to_vertex2dd(100::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).x,
    (seqnum_to_vertex2dd(100::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).y,
    4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
100

# ZORDER uniqueness: different seqnums give different zorder values
query I
SELECT count(DISTINCT seqnum_to_zorder(s::UBIGINT, 5)) = 3
FROM (VALUES (100), (200), (300)) t(s);
----
true

# Z3 error for aperture 7
statement error
SELECT seqnum_to_z3(1::UBIGINT, 4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
Z3 not available

# Z7 error for aperture 3
statement error
SELECT seqnum_to_z7(1::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
Z7 not available

# ============================================================
# Multi-Aperture — additional tests
# ============================================================

# cellAreaKM decreases with higher resolution
query I
SELECT dggs_cell_area_km(1, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'))
     > dggs_cell_area_km(2, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
true

# cellDistKM decreases with higher resolution
query I
SELECT dggs_cell_dist_km(1, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'))
     > dggs_cell_dist_km(2, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
true

# Single aperture 4 matches multi-aperture '4444'
query I
SELECT dggs_n_cells(3, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25))
     = dggs_n_cells(3, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '4444'));
----
true

# Resolution 0 with aperture sequence returns 12 (icosahedron vertices + face centres)
query I
SELECT dggs_n_cells(0, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
12

# FULLER projection works with aperture sequence
query I
SELECT dggs_n_cells(2, dggs_params('FULLER', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '343'));
----
122

# Different pole coordinates work with aperture sequence
query I
SELECT dggs_n_cells(2, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 45.0, 0.0, true, '343'));
----
122

# Different azimuth works with aperture sequence
query I
SELECT dggs_n_cells(2, dggs_params('ISEA', 3, 'HEXAGON', 30.0, 58.28252559, 11.25, true, '343'));
----
122

# geoToSequenceNum works with aperture sequence
query I
SELECT geo_to_seqnum('POINT(10.0 20.0)'::GEOMETRY, 2,
    dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '343')) > 0;
----
true

# sequenceNumToGeo round-trip with aperture sequence
query I
SELECT geo_to_seqnum(
    seqnum_to_geo(10::UBIGINT, 2, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '343')),
    2, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '343'));
----
10

# ============================================================
# Grid Statistics — specific known values (from geo.test.ts)
# ============================================================

query I
SELECT dggs_n_cells(1);
----
42

query I
SELECT dggs_n_cells(3);
----
642

# ============================================================
# Neighbors — Triangle topology error
# ============================================================

statement error
SELECT seqnum_neighbors(1::UBIGINT, 3, dggs_params('ISEA', 4, 'TRIANGLE', 0.0, 58.28252559, 11.25));
----
Neighbors not implemented for Triangle grids

# ============================================================
# Hierarchical addresses — consistency & edge cases
# ============================================================

# VERTEX2DD round-trip for multiple cells
query I
SELECT bool_and(
    vertex2dd_to_seqnum(
        (seqnum_to_vertex2dd(s::UBIGINT, 5)).keep,
        (seqnum_to_vertex2dd(s::UBIGINT, 5)).vert_num,
        (seqnum_to_vertex2dd(s::UBIGINT, 5)).tri_num,
        (seqnum_to_vertex2dd(s::UBIGINT, 5)).x,
        (seqnum_to_vertex2dd(s::UBIGINT, 5)).y, 5) = s::UBIGINT
) FROM (VALUES (10), (20), (30), (40), (50)) t(s);
----
true

# Z3 consistency across resolutions 3-6
query I
SELECT bool_and(
    z3_to_seqnum(seqnum_to_z3(10::UBIGINT, r,
        dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)),
        r, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)) = 10
) FROM (VALUES (3), (4), (5), (6)) t(r);
----
true

# Z7 consistency across resolutions 3-6
query I
SELECT bool_and(
    z7_to_seqnum(seqnum_to_z7(10::UBIGINT, r,
        dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)),
        r, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)) = 10
) FROM (VALUES (3), (4), (5), (6)) t(r);
----
true

# Z7 handles large seqnum values correctly
query I
SELECT z7_to_seqnum(seqnum_to_z7(1000000::UBIGINT, 8,
    dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)),
    8, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
1000000

# All hierarchical types work together (aperture 3, seqnum 50)
query I
SELECT seqnum_to_zorder(50::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)) > 0
   AND seqnum_to_z3(50::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)) > 0
   AND (seqnum_to_vertex2dd(50::UBIGINT, 4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))).keep IS NOT NULL;
----
true

# ============================================================
# Multi-Aperture — additional edge cases
# ============================================================

# Long aperture sequences work
query I
SELECT dggs_n_cells(10, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3477437743774377')) > 0;
----
true

# Aperture 7 differs from aperture 4 and has more cells
query I
SELECT dggs_n_cells(4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25))
    != dggs_n_cells(4)
   AND dggs_n_cells(4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25))
     > dggs_n_cells(4);
----
true

# ============================================================
# IGEO7 / Z7 bit-level operations
#
# Functions operate on the packed 64-bit Z7 index directly —
# no DGGRID call, no dggs_params needed. Bit-level logic is
# ported from https://github.com/allixender/igeo7_duckdb
# ============================================================

# ── String ↔ packed integer round trip ──────────────────────

query I
SELECT igeo7_to_string(igeo7_from_string('0800432'));
----
0800432

query I
SELECT igeo7_get_resolution(igeo7_from_string('0800432'));
----
5

query I
SELECT igeo7_get_base_cell(igeo7_from_string('0800432'));
----
8

# ── Digit extraction (positions 1..5 meaningful, rest padding) ──

query IIIIIIII
SELECT
    igeo7_get_digit(igeo7_from_string('0800432'), 1),
    igeo7_get_digit(igeo7_from_string('0800432'), 2),
    igeo7_get_digit(igeo7_from_string('0800432'), 3),
    igeo7_get_digit(igeo7_from_string('0800432'), 4),
    igeo7_get_digit(igeo7_from_string('0800432'), 5),
    igeo7_get_digit(igeo7_from_string('0800432'), 6),
    igeo7_get_digit(igeo7_from_string('0800432'), 20),
    igeo7_get_digit(igeo7_from_string('0800432'), 99);
----
0	0	4	3	2	7	7	7

# ── Encode is inverse of from_string ─────────────────────────

query I
SELECT igeo7_encode(8, 0,0,4,3,2, 7,7,7,7,7, 7,7,7,7,7, 7,7,7,7,7)
     = igeo7_from_string('0800432');
----
true

# Known packed value at resolution 13 (from upstream README)
query I
SELECT igeo7_encode(0, 0,1,6,1,6,1,2,0,6,2,4,1,3, 7,7,7,7,7,7,7)
     = 32023330408103935::UBIGINT;
----
true

# ── igeo7_encode_at_resolution matches parent_at ∘ encode ────

query I
SELECT igeo7_encode_at_resolution(8, 3,
           0,0,4,3,2, 7,7,7,7,7, 7,7,7,7,7, 7,7,7,7,7)
     = igeo7_parent_at(
           igeo7_encode(8, 0,0,4,3,2, 7,7,7,7,7, 7,7,7,7,7, 7,7,7,7,7), 3);
----
true

query I
SELECT igeo7_to_string(
    igeo7_encode_at_resolution(8, 3,
        0,0,4,3,2, 7,7,7,7,7, 7,7,7,7,7, 7,7,7,7,7));
----
08004

# ── Parent / parent_at ───────────────────────────────────────

query I
SELECT igeo7_to_string(igeo7_parent(igeo7_from_string('0800432')));
----
080043

query I
SELECT igeo7_to_string(igeo7_parent_at(igeo7_from_string('0800432'), 3));
----
08004

# Climbing with igeo7_parent reduces resolution by 1 each step
query I
SELECT igeo7_get_resolution(
    igeo7_parent(igeo7_parent(igeo7_parent(igeo7_from_string('0800432')))));
----
2

# ── Neighbours ───────────────────────────────────────────────

query I
SELECT list_transform(
    igeo7_get_neighbours(igeo7_from_string('0800432')),
    x -> igeo7_to_string(x))
    = ['0800433', '0800651', '0800064', '0800436', '0800430', '0800655'];
----
true

query I
SELECT igeo7_to_string(igeo7_get_neighbour(igeo7_from_string('0800432'), 1));
----
0800433

# Out-of-range direction returns the invalid sentinel (UINT64_MAX)
query I
SELECT igeo7_get_neighbour(igeo7_from_string('0800432'), 0)
     = 18446744073709551615::UBIGINT
   AND igeo7_get_neighbour(igeo7_from_string('0800432'), 7)
     = 18446744073709551615::UBIGINT;
----
true

# ── is_valid / first_non_zero ────────────────────────────────

query I
SELECT igeo7_is_valid(igeo7_from_string('0800432'))
   AND NOT igeo7_is_valid(18446744073709551615::UBIGINT);
----
true

# First non-zero digit position for '0800432' (d1=0, d2=0, d3=4) is 3
query I
SELECT igeo7_first_non_zero(igeo7_from_string('0800432'));
----
3

# ── Verbose decode macro ─────────────────────────────────────

query I
SELECT igeo7_decode_str(32023330408103935::UBIGINT);
----
0-0.1.6.1.6.1.2.0.6.2.4.1.3.7.7.7.7.7.7.7

# ── String-domain macros ─────────────────────────────────────

query III
SELECT
    igeo7_string_parent('0800432'),
    igeo7_string_local_pos('0800432'),
    igeo7_string_is_center('080040');
----
080043	2	true

query I
SELECT igeo7_string_is_center('0800432');
----
false

# ── Composition with DGGRID-backed seqnum_to_z7 ──────────────
# Confirms the DGGRID Z7 value and the bit-level functions use
# the same packing (base cell + 20×3-bit digits).

query I
SELECT igeo7_get_resolution(
    seqnum_to_z7(100::UBIGINT, 4,
        dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)));
----
4

query I
SELECT igeo7_is_valid(
    seqnum_to_z7(100::UBIGINT, 4,
        dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)));
----
true

# ── WGS84 geodetic ↔ authalic latitude conversion ────────────
# Karney 2022 polynomial (order 6) Fourier series. Surfaces the
# latitude remap from third_party/igeo7_duckdb/src/auth/. The
# transform only touches the Y component; X / Z / M pass through.
# These tests deliberately avoid the spatial extension's ST_*
# helpers so the suite still passes without `LOAD spatial`.

# Equator and both poles are fixed points of the mapping (string
# comparison of the canonical GEOMETRY form).
query III
SELECT
    igeo7_geo_to_authalic('POINT (0 0)'::GEOMETRY)::VARCHAR,
    igeo7_geo_to_authalic('POINT (45 90)'::GEOMETRY)::VARCHAR,
    igeo7_geo_to_authalic('POINT (45 -90)'::GEOMETRY)::VARCHAR;
----
POINT (0 0)	POINT (45 90)	POINT (45 -90)

# Expected value at φ=45°: ξ ≈ 44.8717028734° (Karney 2022).
query I
SELECT igeo7_geo_to_authalic('POINT (0 45)'::GEOMETRY)::VARCHAR;
----
POINT (0 44.87170287343394)

# Mapping is odd: ξ(-φ) = -ξ(φ). Compare the two canonical forms
# differ only by a leading minus on the second coordinate.
query I
SELECT
    igeo7_geo_to_authalic('POINT (0 -45)'::GEOMETRY)::VARCHAR;
----
POINT (0 -44.87170287343394)

# Round-trip preserves a POINT exactly (canonical string equality).
query I
SELECT igeo7_authalic_to_geo(
           igeo7_geo_to_authalic('POINT (-71.5 42.3)'::GEOMETRY)
       )::VARCHAR;
----
POINT (-71.5 42.3)

# POLYGON: every vertex Y is remapped, X/closure preserved.
query I
SELECT igeo7_geo_to_authalic(
    'POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0))'::GEOMETRY
)::VARCHAR;
----
POLYGON ((0 0, 10 0, 10 9.956198098935733, 0 9.956198098935733, 0 0))

# LINESTRING with multiple latitudes.
query I
SELECT igeo7_geo_to_authalic(
    'LINESTRING (0 0, 0 30, 0 60)'::GEOMETRY
)::VARCHAR;
----
LINESTRING (0 0, 0 29.888997034459564, 0 59.88878556988515)

# MULTIPOLYGON exercises the recursive walker over collection parts.
query I
SELECT igeo7_geo_to_authalic(
    'MULTIPOLYGON (((0 0, 10 0, 10 10, 0 10, 0 0)),
                   ((20 20, 30 20, 30 30, 20 30, 20 20)))'::GEOMETRY
)::VARCHAR;
----
MULTIPOLYGON (((0 0, 10 0, 10 9.956198098935733, 0 9.956198098935733, 0 0)), ((20 19.917652210017884, 30 19.917652210017884, 30 29.888997034459564, 20 29.888997034459564, 20 19.917652210017884)))

# GEOMETRYCOLLECTION: heterogeneous parts all transformed.
query I
SELECT igeo7_geo_to_authalic(
    'GEOMETRYCOLLECTION (POINT (0 45), LINESTRING (0 0, 0 30))'::GEOMETRY
)::VARCHAR;
----
GEOMETRYCOLLECTION (POINT (0 44.87170287343394), LINESTRING (0 0, 0 29.888997034459564))

# Round-trip preserves a polygon exactly (string-equal canonical form).
query I
SELECT igeo7_authalic_to_geo(igeo7_geo_to_authalic(g))::VARCHAR = g::VARCHAR
FROM (VALUES ('POLYGON ((-71.5 42.3, -70 42.3, -70 43, -71.5 43, -71.5 42.3))'::GEOMETRY)) t(g);
----
true


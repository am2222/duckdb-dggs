# name: test/sql/duck_dggs.test
# description: test duck_dggs extension
# group: [sql]

require duck_dggs

# ============================================================
# Utility
# ============================================================

query I
SELECT duck_dggs_version() != '';
----
true

# ============================================================
# FROM GEO — (lon=0.0, lat=0.0, res=5)
#
# NOTE: (0.0, 0.0) sits on an icosahedron face boundary.
# DGGRID assigns it to one of the adjacent cells depending on
# floating-point evaluation order, which differs between x86
# (80-bit x87 long double) and ARM/macOS (64-bit double).
# Integer results (seqnum, q2di quad/i/j) are stable; all
# continuous-coordinate results use fuzzy comparisons.
# ============================================================

query I
SELECT geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 5);
----
2380

query I
SELECT geo_to_q2di('POINT(0.0 0.0)'::GEOMETRY, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# geo_to_q2dd: quad is an integer (stable); x and y are continuous
# coordinates whose last bits differ between x86 and ARM.
query I
SELECT (geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).quad = 3
   AND abs((geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.16325419438415284) < 1e-9
   AND abs((geo_to_q2dd('POINT(0.0 0.0)'::GEOMETRY, 5)).y - 0.282764559254556) < 1e-9;
----
true

# geo_to_projtri: (0,0) lands on the boundary between icosahedron triangles 2
# and 7.  Accept either adjacent triangle; check coordinates to 1e-9.
query I
SELECT
  (((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).tnum = 7 AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.6734916112035678) < 1e-9)
   OR
   ((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).tnum = 2 AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 0.32650838876079025) < 1e-9))
  AND abs((geo_to_projtri('POINT(0.0 0.0)'::GEOMETRY, 5)).y) < 1e-9;
----
true

query I
SELECT geo_to_geo('POINT(0.0 0.0)'::GEOMETRY, 5);
----
POINT (0 0)

# geo_to_plane: (0,0) sits on a plane-triangle boundary; x shifts by exactly
# 1.0 between platforms.  y is √3 on both platforms — check within 1e-9.
query I
SELECT
  (abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 3.326508388796432)   < 1e-9
   OR abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).x - 2.3265083887607902) < 1e-9)
  AND abs((geo_to_plane('POINT(0.0 0.0)'::GEOMETRY, 5)).y - 1.7320508075851162) < 1e-9;
----
true

# ============================================================
# FROM SEQNUM — (seqnum=2380, res=5)
# ============================================================

query I
SELECT seqnum_to_q2di(2380, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# seqnum_to_q2dd: x = 5/32 (exact); y is a continuous value that may
# differ in the last bits across platforms.
query I
SELECT (seqnum_to_q2dd(2380, 5)).quad = 3
   AND (seqnum_to_q2dd(2380, 5)).x = 0.15625
   AND abs((seqnum_to_q2dd(2380, 5)).y - 0.27063293868263705) < 1e-9;
----
true

# seqnum_to_projtri: x is very close to 11/16 = 0.6875; y is essentially
# zero (floating-point noise) — check abs(y) < 1e-9.
query I
SELECT (seqnum_to_projtri(2380, 5)).tnum = 7
   AND abs((seqnum_to_projtri(2380, 5)).x - 0.6875) < 1e-9
   AND abs((seqnum_to_projtri(2380, 5)).y) < 1e-9;
----
true

# seqnum_to_plane: x = 37/16 (exact); y is approximately √3 and may
# differ in the last bits across platforms.
query I
SELECT (seqnum_to_plane(2380, 5)).x = 2.3125
   AND abs((seqnum_to_plane(2380, 5)).y - 1.7320508075688774) < 1e-9;
----
true

# seqnum_to_seqnum is a round-trip identity
query I
SELECT seqnum_to_seqnum(2380, 5);
----
2380

# ============================================================
# FROM Q2DI — (quad=3, i=10, j=10, res=5)
# ============================================================

query I
SELECT q2di_to_seqnum(3, 10, 10, 5);
----
2380

query I
SELECT q2di_to_q2di(3, 10, 10, 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# q2di_to_q2dd: same result as seqnum_to_q2dd — same fuzzy check.
query I
SELECT (q2di_to_q2dd(3, 10, 10, 5)).quad = 3
   AND (q2di_to_q2dd(3, 10, 10, 5)).x = 0.15625
   AND abs((q2di_to_q2dd(3, 10, 10, 5)).y - 0.27063293868263705) < 1e-9;
----
true

# ============================================================
# Round-trips
# ============================================================

# geo → seqnum → geo → seqnum must be stable (cell centre)
query I
SELECT geo_to_seqnum(seqnum_to_geo(2380, 5), 5);
----
2380

# q2di → seqnum → q2di must be stable
query I
SELECT seqnum_to_q2di(q2di_to_seqnum(3, 10, 10, 5), 5);
----
{'quad': 3, 'i': 10, 'j': 10}

# seqnum → q2di → seqnum must be stable
query I
SELECT q2di_to_seqnum((seqnum_to_q2di(2380, 5)).quad, (seqnum_to_q2di(2380, 5)).i, (seqnum_to_q2di(2380, 5)).j, 5);
----
2380

# ============================================================
# Vectorised — works on a table of values
# ============================================================

query I
SELECT count(*) = 3 FROM (
    SELECT geo_to_seqnum(geom, 5)
    FROM (VALUES ('POINT(0.0 0.0)'::GEOMETRY), ('POINT(10.0 20.0)'::GEOMETRY), ('POINT(-45.0 60.0)'::GEOMETRY)) t(geom)
);
----
true

# Different resolutions produce different cell counts
query I
SELECT geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 1) != geo_to_seqnum('POINT(0.0 0.0)'::GEOMETRY, 5);
----
true

# ============================================================
# dggs_params — 8-arg overload (aperture sequence support)
# ============================================================

# 6-arg overload defaults is_aperture_sequence=false
query I
SELECT (dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)).is_aperture_sequence;
----
false

# 6-arg overload defaults aperture_sequence=''
query I
SELECT (dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)).aperture_sequence;
----
(empty)

# 8-arg overload sets is_aperture_sequence
query I
SELECT (dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3437')).is_aperture_sequence;
----
true

# 8-arg overload sets aperture_sequence
query I
SELECT (dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3437')).aperture_sequence;
----
3437

# ============================================================
# Grid Statistics — dggs_n_cells, dggs_cell_area_km,
#                   dggs_cell_dist_km, dggs_cls_km,
#                   dggs_res_info
# ============================================================

# Known cell count for ISEA4H at res 4
query I
SELECT dggs_n_cells(4);
----
2562

# Known cell count at res 5
query I
SELECT dggs_n_cells(5);
----
10242

# Higher resolution has more cells
query I
SELECT dggs_n_cells(5) > dggs_n_cells(4);
----
true

# Higher resolution has smaller area per cell
query I
SELECT dggs_cell_area_km(5) < dggs_cell_area_km(4);
----
true

# All stats are positive
query I
SELECT dggs_cell_area_km(4) > 0
   AND dggs_cell_dist_km(4) > 0
   AND dggs_cls_km(4) > 0;
----
true

# dggs_res_info struct fields match individual functions
query I
SELECT (dggs_res_info(4)).cells = dggs_n_cells(4);
----
true

query I
SELECT (dggs_res_info(4)).res = 4;
----
true

# Params overload: stats with explicit default params match base overload
query I
SELECT dggs_n_cells(4, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25)) = dggs_n_cells(4);
----
true

# Different aperture gives different cell count
query I
SELECT dggs_n_cells(4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25))
    != dggs_n_cells(4);
----
true

# ── aperture sequence grid stats ────────────────────────────

# Aperture sequence produces a different cell count than fixed aperture
query I
SELECT dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'))
    != dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

query I
SELECT dggs_n_cells(3, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
362

# ============================================================
# Neighbors — seqnum_neighbors
# ============================================================

# Interior hexagon cell has 6 neighbors
query I
SELECT len(seqnum_neighbors(2380::UBIGINT, 5));
----
6

# A cell is not its own neighbor
query I
SELECT list_contains(seqnum_neighbors(2380::UBIGINT, 5), 2380::UBIGINT);
----
false

# Neighbor relationship is symmetric
query I
SELECT list_contains(seqnum_neighbors(2412::UBIGINT, 5), 2380::UBIGINT);
----
true

# Params overload matches base form
query I
SELECT seqnum_neighbors(2380::UBIGINT, 5)
     = seqnum_neighbors(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# Vectorised over a table
query I
SELECT count(*) = 3 FROM (
  SELECT seqnum_neighbors(seqnum, 5)
  FROM (VALUES (2380::UBIGINT), (2381::UBIGINT), (100::UBIGINT)) t(seqnum)
);
----
true

# ============================================================
# Parent — seqnum_parent
# ============================================================

query I
SELECT seqnum_parent(2380::UBIGINT, 5);
----
599

# Parent is at the coarser resolution: its children include the original cell
query I
SELECT list_contains(
    seqnum_children(seqnum_parent(2380::UBIGINT, 5), 4),
    2380::UBIGINT
);
----
true

# Params overload matches base form
query I
SELECT seqnum_parent(2380::UBIGINT, 5)
     = seqnum_parent(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Children — seqnum_children
# ============================================================

# Aperture 4 hexagon cell has 7 children (1 interior + 6 boundary)
query I
SELECT len(seqnum_children(599::UBIGINT, 4));
----
7

# The interior child's parent is the original cell
query I
SELECT seqnum_parent((seqnum_children(599::UBIGINT, 4))[1], 5);
----
599

# Params overload matches base form
query I
SELECT seqnum_children(599::UBIGINT, 4)
     = seqnum_children(599::UBIGINT, 4, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Hierarchical addresses — ZOrder, Z3, Z7 round-trips
# ============================================================

# ── ZOrder (default aperture 4) ─────────────────────────────

query I
SELECT zorder_to_seqnum(seqnum_to_zorder(2380::UBIGINT, 5), 5);
----
2380

# ── Z3 (requires aperture 3) ────────────────────────────────

query I
SELECT z3_to_seqnum(
    seqnum_to_z3(100::UBIGINT, 4,
        dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25)),
    4, dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
100

# ── Z7 (requires aperture 7) ────────────────────────────────

query I
SELECT z7_to_seqnum(
    seqnum_to_z7(100::UBIGINT, 4,
        dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25)),
    4, dggs_params('ISEA', 7, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
100

# ZOrder params overload matches base form (default is aperture 4)
query I
SELECT seqnum_to_zorder(2380::UBIGINT, 5)
     = seqnum_to_zorder(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# All Parents — seqnum_all_parents
# ============================================================

# Interior cell: all_parents returns exactly the primary parent
query I
SELECT len(seqnum_all_parents(2380::UBIGINT, 5));
----
1

# Primary parent is the first element
query I
SELECT (seqnum_all_parents(2380::UBIGINT, 5))[1] = seqnum_parent(2380::UBIGINT, 5);
----
true

# Boundary cell (2412 sits on the boundary between parents) has multiple parents
query I
SELECT len(seqnum_all_parents(2412::UBIGINT, 5)) > 1;
----
true

# The primary (containing) parent is always in the list
query I
SELECT list_contains(
    seqnum_all_parents(2412::UBIGINT, 5),
    seqnum_parent(2412::UBIGINT, 5)
);
----
true

# Params overload matches base form
query I
SELECT seqnum_all_parents(2380::UBIGINT, 5)
     = seqnum_all_parents(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Vertex2DD — seqnum_to_vertex2dd, vertex2dd_to_seqnum
# ============================================================

# Round-trip: vertex2dd → seqnum recovers the original
query I
SELECT vertex2dd_to_seqnum(
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).keep,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).vert_num,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).tri_num,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).x,
    (seqnum_to_vertex2dd(2380::UBIGINT, 5)).y,
    5
);
----
2380

# Struct fields have expected types: keep is boolean, vert_num/tri_num are ints
query I
SELECT (seqnum_to_vertex2dd(2380::UBIGINT, 5)).keep;
----
true

# Params overload matches base form
query I
SELECT seqnum_to_vertex2dd(2380::UBIGINT, 5)
     = seqnum_to_vertex2dd(2380::UBIGINT, 5, dggs_params('ISEA', 4, 'HEXAGON', 0.0, 58.28252559, 11.25));
----
true

# ============================================================
# Aperture sequence — transforms
# ============================================================

# seqnum round-trip through aperture-sequence grid
query I
SELECT seqnum_to_seqnum(100::UBIGINT, 3,
    dggs_params('ISEA', 3, 'HEXAGON', 0.0, 58.28252559, 11.25, true, '3434'));
----
100

